### Variables
set {
    # Mod1 == Alt, Mod4 == Win on malgudi.   
    # I need my alt for emacs...duh!!!
    $mod    Mod4

    $left   h
    $down   j
    $up     k
    $right  l

    $term   foot
    $menu   wofi --show=drun --lines=5 --prompt=""
}


### Colours
set {
    $white          #ffffff
    $cyan           #00afd7
    $acqua          #00d787
    $wine           #72003e
    $magenta        #af005f
    $orange         #ff8700
    $silver         #e4e4e4
    $elegant        #1b1d1e
    $transparent    #000000
    #$transparent    #0000007f

    $background     "/home/kannan/Pictures/2017-06-09-assets-natgeotv.fnghub.com:POD:7871.jpg"
}

# Set some nice            colors      border      background    text        indicator    child_border
client.focused             $elegant    $cyan       $elegant      $white      $cyan
client.unfocused           $elegant    $elegant    $orange       $white      $elegant
client.focused_inactive    $elegant    $elegant    $acqua        $magenta    $acqua
client.urgent              $elegant    $magenta    $silver       $magenta    $magenta
client.placeholder         $elegant    $magenta    $silver       $white      $magenta

exec {

    XDG_CURRENT_DESKTOP=sway
    systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
    dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

    1password

    firefox-developer-edition

    $term --app-id netSkope  
    # slack
    whatsapp-for-linux
    emacs

    $term --app-id monitors  -T "__htop__"            -e htop
    $term --app-id speedtest -T "watch speedtest-cli" -e watch -cd -n 600 sptest   
    $term --app-id speedtest -T "_speedtest results_" -e tail -f $HOME/tmp/sptest.txt

    swayidle -w -d                                  \
         timeout 300 'swaylock -f -c 000000'        \
         timeout 600 'swaymsg "output * dpms off"'  \
              resume 'swaymsg "output * dpms on"'   \
        before-sleep 'swaylock -f -c 000000'

    gammastep 

    sh -c 'rm -f /tmp/sovpipe && mkfifo /tmp/sovpipe && tail -f /tmp/sovpipe | sov -n -t 500'
}

bindsym {
    $mod+Return         exec $term
    $mod+n              exec $term
    $mod+q              kill
    $mod+d              exec $menu
    $mod+Shift+c        reload
    $mod+Shift+x        exec swaymsg exit
}

set {
    $Monitors $ws1
    $Browsers $ws2
    $netSkope $ws3
    $Editors  $ws4
    $Social   $ws9
    $Secrets  $ws10
}

for_window {
    [app_id="speedtest"]    move container to workspace $Monitors, focus, split v
    [app_id="monitors"]     move container to workspace $Monitors, focus, split h
    [app_id=".*firefox.*"]  move container to workspace $Browsers
    [class="Slack"]         move container to workspace $netSkope
    [app_id="netSkope"]     move container to workspace $netSkope
    [class="1Password"]     move container to workspace $Secrets
    [app_id="emacs"]        move container to workspace $Editors
    [app_id="whatsapp.*"]   move container to workspace $Social
}

##
# Layout stuff:
#
bindsym {
    $mod+s              layout stacking
    $mod+t              layout tabbed
    $mod+e              layout toggle split
    $mod+f              fullscreen
    $mod+Shift+space    floating toggle
    $mod+space          focus mode_toggle
    $mod+tab            workspace back_and_forth

    $mod+bar            splith
    $mod+backslash      splith
    $mod+equal          splitv
    #$mod+minus         splitv
}

### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
# output * bg $background fill

### Input configuration
#
input <identifier> xkb_model "pc101" 
input type:touchpad {
    tap enabled
    tap_button_map lmr
    click_method   button_areas
    natural_scroll disabled
    scroll_method  two_finger
}

### Key bindings
#

bindsym $mod+Shift+$left    move left
bindsym $mod+Shift+$down    move down
bindsym $mod+Shift+$up      move up
bindsym $mod+Shift+$right   move right
bindsym $mod+Shift+Left     move left
bindsym $mod+Shift+Down     move down
bindsym $mod+Shift+Up       move up
bindsym $mod+Shift+Right    move right

