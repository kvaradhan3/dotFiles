#
# MacOSX directives
#
Host netskope
  HostName              github.com
  User                  git
  PreferredAuthentications publickey
  ForwardX11            no
  IdentityFile          ~/.ssh/id_ed25519_netSkope

Host github.com
  HostName              github.com
  User                  git
  PreferredAuthentications publickey
  ForwardX11            no
  IdentityFile          ~/.ssh/id_ed25519_github

Host *
  IdentityAgent "~/.1password/agent.sock"
  User          kannan
  ForwardAgent  yes
  ForwardX11    yes
